{
  "permissions": {
    "allow": [
      "Bash(npm run lint:*)",
      "Bash(npm test:*)",
      "Bash(node:test:*)"
    ]
  },
  "hooks": {
    "PostToolUse": {
      "trigger": "Edit|Write",
      "command": "bash scripts/set_dirty_bit.sh ${tool},${target}"
    },
    "Stop": {
      "command": "bash scripts/verify_before_exit.sh"
    }
  }
}
